{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "azureUserName": {
      "type": "string",
      "metadata": {
        "description": "Azure AD User UPN"
      }
    },
    "azurePassword": {
      "type": "securestring",
      "metadata": {
        "description": "Azure AD User Password"
      }
    },
    "azureTAP": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Temporary Access Pass (optional)"
      }
    },
    "azureTAPExpiry": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "TAP Expiry DateTime ISO format (optional)"
      }
    },
    "ODLID": {
      "type": "string",
      "metadata": {
        "description": "CloudLabs ODL ID"
      }
    },
    "DeploymentID": {
      "type": "string",
      "metadata": {
        "description": "Unique Deployment ID"
      }
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "LabAdmin",
      "metadata": {
        "description": "VM Admin Username"
      }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "VM Admin Password"
      }
    },
    "trainerUserName": {
      "type": "string",
      "defaultValue": "trainer",
      "metadata": {
        "description": "Trainer Username for Shadow"
      }
    },
    "trainerUserPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Trainer Password"
      }
    },
    "tenantDomain": {
      "type": "string",
      "metadata": {
        "description": "Tenant FQDN (e.g., contoso.onmicrosoft.com)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "AzureUserObjectID": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Azure User Object ID"
      }
    }
  },
  "variables": {
    "AzureTenantID": "[subscription().tenantId]",
    "AzureSubscriptionID": "[subscription().subscriptionId]",
    "rgName": "[resourceGroup().name]",

    "labVMName": "[concat('LabVM-', parameters('DeploymentID'))]",
    "labVMNicName": "[concat('labvm-', parameters('DeploymentID'), '-nic')]",
    "labVMPipName": "[concat('labvm-', parameters('DeploymentID'), '-pip')]",
    "labVMPipDnsName": "[concat('labvm', parameters('DeploymentID'))]",
    "labVMNsgName": "[concat('labvm-', parameters('DeploymentID'), '-nsg')]",
    "labVMVnetName": "[concat('labvm-', parameters('DeploymentID'), '-vnet')]",
    "labVMSubnetName": "default",
    "labVMSubnetRef": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('labVMVnetName'), variables('labVMSubnetName'))]",

    "sentinelRGName": "[concat('UniSecOps-RG-', parameters('DeploymentID'))]",
    "workspaceName": "[concat('UniSecOps-sentinel-', parameters('DeploymentID'))]",

    "cloudlabsCommon": "[concat(' -AzureUserName \"', parameters('azureUserName'), '\" -AzurePassword \"', parameters('azurePassword'), '\" -AzureTAP \"', parameters('azureTAP'), '\" -AzureTAPExpiry \"', parameters('azureTAPExpiry'), '\" -AzureTenantID \"', variables('AzureTenantID'), '\" -AzureSubscriptionID \"', variables('AzureSubscriptionID'), '\" -ODLID \"', parameters('ODLID'), '\" -DeploymentID \"', parameters('DeploymentID'), '\" -adminPassword \"', parameters('adminPassword'), '\" -ResourceGroupName \"', variables('rgName'), '\" -WorkspaceName \"', variables('workspaceName'), '\" -Location \"', parameters('location'), '\"')]",
    "cloudlabsShadow": "[concat(' -vmAdminUsername \"', parameters('adminUsername'), '\" -trainerUserName \"', parameters('trainerUserName'), '\" -trainerUserPassword \"', parameters('trainerUserPassword'), '\"')]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-11-01",
      "name": "[variables('labVMNsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "Allow-RDP",
            "properties": {
              "priority": 1000,
              "protocol": "TCP",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "3389"
            }
          },
          {
            "name": "Allow-SSH",
            "properties": {
              "priority": 1010,
              "protocol": "TCP",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "22"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-11-01",
      "name": "[variables('labVMVnetName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('labVMNsgName'))]"
      ],
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "10.0.0.0/16"
          ]
        },
        "subnets": [
          {
            "name": "[variables('labVMSubnetName')]",
            "properties": {
              "addressPrefix": "10.0.0.0/24",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('labVMNsgName'))]"
              }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "[variables('labVMPipName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "dnsSettings": {
          "domainNameLabel": "[variables('labVMPipDnsName')]"
        }
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-11-01",
      "name": "[variables('labVMNicName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('labVMVnetName'))]",
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('labVMPipName'))]"
      ],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": {
                "id": "[variables('labVMSubnetRef')]"
              },
              "privateIPAllocationMethod": "Dynamic",
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('labVMPipName'))]"
              }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-03-01",
      "name": "[variables('labVMName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', variables('labVMNicName'))]"
      ],
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "hardwareProfile": {
          "vmSize": "Standard_D4s_v3"
        },
        "osProfile": {
          "computerName": "[variables('labVMName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "windowsConfiguration": {
            "provisionVMAgent": true,
            "enableAutomaticUpdates": false
          }
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "microsoftwindowsdesktop",
            "offer": "office-365",
            "sku": "win11-24h2-avd-m365",
            "version": "latest"
          },
          "osDisk": {
            "createOption": "FromImage",
            "name": "[concat(variables('labVMName'), '-osdisk')]",
            "managedDisk": {
              "storageAccountType": "Premium_LRS"
            }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('labVMNicName'))]"
            }
          ]
        },
        "diagnosticsProfile": {
          "bootDiagnostics": {
            "enabled": true
          }
        }
      }
    },
    {
      "comments": "Assign Owner role to VM Managed Identity at RG level.",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceGroup().id, variables('labVMName'), 'Owner')]",
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('labVMName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Authorization/roleDefinitions/8e3af657-a8ff-443c-a75c-2fe8c4bcb635')]",
        "principalId": "[reference(resourceId('Microsoft.Compute/virtualMachines', variables('labVMName')), '2024-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines/runCommands",
      "apiVersion": "2024-03-01",
      "name": "[concat(variables('labVMName'), '/EnableSSH')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('labVMName'))]"
      ],
      "properties": {
        "source": {
          "script": "Add-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0 -ErrorAction SilentlyContinue; Set-Service -Name sshd -StartupType Automatic; Start-Service sshd; New-NetFirewallRule -Name 'OpenSSH-Server-In-TCP' -DisplayName 'OpenSSH Server (sshd)' -Enabled True -Direction Inbound -Protocol TCP -Action Allow -LocalPort 22 -ErrorAction SilentlyContinue; New-ItemProperty -Path 'HKLM:\\SOFTWARE\\OpenSSH' -Name DefaultShell -Value 'C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe' -PropertyType String -Force -ErrorAction SilentlyContinue; Write-Output 'SSH Server Enabled'"
        },
        "timeoutInSeconds": 300,
        "treatFailureAsDeploymentFailure": false
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2024-03-01",
      "name": "[concat(variables('labVMName'), '/BootstrapScript')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines/runCommands', variables('labVMName'), 'EnableSSH')]"
      ],
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "CustomScriptExtension",
        "typeHandlerVersion": "1.10",
        "autoUpgradeMinorVersion": true,
        "settings": {
          "fileUris": [
            "https://experienceazure.blob.core.windows.net/templates/cloudlabs-common/cloudlabs-windows-functions.ps1",
            "https://srikanth98493.blob.core.windows.net/unisecops/psscriptspn.ps1"
          ]
        },
        "protectedSettings": {
          "commandToExecute": "[concat('powershell.exe -ExecutionPolicy Bypass -Command \"', 'New-Item -Path C:\\LabFiles -ItemType Directory -Force; ', 'Copy-Item -Path .\\psscriptspn.ps1 -Destination C:\\LabFiles\\psscriptspn.ps1 -Force; ', 'Copy-Item -Path .\\cloudlabs-common\\cloudlabs-windows-functions.ps1 -Destination C:\\LabFiles\\cloudlabs-windows-functions.ps1 -Force; ', '$action = New-ScheduledTaskAction -Execute ''powershell.exe'' -Argument ''-ExecutionPolicy Bypass -File C:\\LabFiles\\psscriptspn.ps1', variables('cloudlabsCommon'), variables('cloudlabsShadow'), '''; ', '$trigger = New-ScheduledTaskTrigger -Once -At (Get-Date).AddSeconds(10); ', '$settings = New-ScheduledTaskSettingsSet -AllowStartIfOnBatteries -DontStopIfGoingOnBatteries -StartWhenAvailable; ', 'Register-ScheduledTask -TaskName ''BootstrapUniSecOps'' -Action $action -Trigger $trigger -Settings $settings -User ''SYSTEM'' -RunLevel Highest -Force; ', 'Start-ScheduledTask -TaskName ''BootstrapUniSecOps''; ', 'Write-Output ''Bootstrap scheduled and started''\"')]"
        }
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('workspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 90,
        "features": {
          "enableLogAccessUsingOnlyResourcePermissions": true
        },
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      }
    },
    {
      "type": "Microsoft.OperationsManagement/solutions",
      "apiVersion": "2015-11-01-preview",
      "name": "[concat('SecurityInsights(', variables('workspaceName'), ')')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
      ],
      "properties": {
        "workspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
      },
      "plan": {
        "name": "[concat('SecurityInsights(', variables('workspaceName'), ')')]",
        "publisher": "Microsoft",
        "product": "OMSGallery/SecurityInsights",
        "promotionCode": ""
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/onboardingStates",
      "apiVersion": "2022-12-01-preview",
      "name": "[concat(variables('workspaceName'), '/Microsoft.SecurityInsights/default')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]",
        "[resourceId('Microsoft.OperationsManagement/solutions', concat('SecurityInsights(', variables('workspaceName'), ')'))]"
      ],
      "properties": {}
    }
  ],
  "outputs": {
    "DeploymentID": {
      "type": "string",
      "value": "[parameters('DeploymentID')]"
    },
    "LabVM DNS Name": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('labVMPipName'))).dnsSettings.fqdn]"
    },
    "LabVM Admin Username": {
      "type": "string",
      "value": "[parameters('adminUsername')]"
    },
    "LabVM Admin Password": {
      "type": "string",
      "value": "[parameters('adminPassword')]"
    },
    "Azure Username": {
      "type": "string",
      "value": "[parameters('azureUserName')]"
    },
    "Azure Password": {
      "type": "string",
      "value": "[parameters('azurePassword')]"
    },
    "Azure TAP": {
      "type": "string",
      "value": "[if(empty(parameters('azureTAP')), 'Will be generated during bootstrap', parameters('azureTAP'))]"
    },
    "Tenant Domain": {
      "type": "string",
      "value": "[parameters('tenantDomain')]"
    },
    "Tenant ID": {
      "type": "string",
      "value": "[variables('AzureTenantID')]"
    },
    "Subscription ID": {
      "type": "string",
      "value": "[variables('AzureSubscriptionID')]"
    },
    "Sentinel Workspace": {
      "type": "string",
      "value": "[variables('workspaceName')]"
    },
    "Sentinel Resource Group": {
      "type": "string",
      "value": "[variables('rgName')]"
    },
    "Sentinel URL": {
      "type": "string",
      "value": "[concat('https://portal.azure.com/#blade/Microsoft_Azure_Security_Insights/MainMenuBlade/0/subscriptionId/', variables('AzureSubscriptionID'), '/resourceGroup/', variables('rgName'), '/workspaceName/', variables('workspaceName'))]"
    },
    "VM Principal ID": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Compute/virtualMachines', variables('labVMName')), '2024-03-01', 'full').identity.principalId]"
    },
    "Region": {
      "type": "string",
      "value": "[parameters('location')]"
    },
    "Trainer Password": {
      "type": "string",
      "value": "[parameters('trainerUserPassword')]"
    }
  }
}
